# ═══════════════════════════════════════════════════════════
# REQUIRED — the app needs these to function
# ═══════════════════════════════════════════════════════════

# ── Dropbox ─────────────────────────────────────────────────
# Local path to your Dropbox folder (synced by Dropbox desktop client)
DROPBOX_LOCAL_PATH=C:\Users\YourName\Dropbox\Receipts

# ── Email (SMTP) ────────────────────────────────────────────
# Gmail with app password recommended
# https://myaccount.google.com/apppasswords (requires 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your.email@gmail.com

# ── Bookkeeper Emails ──────────────────────────────────────
# Receipts are emailed to these addresses based on category
EMAIL_LEVERANTORSFAKTURA=bookkeeper-invoices@example.com
EMAIL_ANNAT=bookkeeper-other@example.com

# ═══════════════════════════════════════════════════════════
# OPTIONAL — configure as needed
# ═══════════════════════════════════════════════════════════

# ── OCR Backend ──────────────────────────────────────────────
# Options: auto, claude, gpt4, local, gemma, easyocr, tesseract
# "auto" picks the best available: Claude > GPT-4 > local > EasyOCR
OCR_BACKEND=auto

# ── AI API Keys (only needed for gpt4 or claude backends) ───
# Anthropic (Claude Vision)
ANTHROPIC_API_KEY=
# OpenAI (GPT-4 Vision)
OPENAI_API_KEY=

# ── Local Vision Model (advanced — free, no API needed) ─────
# Path to Qwen2.5-VL GGUF model file
LOCAL_VISION_MODEL=
# Path to mmproj file for the model
LOCAL_VISION_MMPROJ=

# ── Gemma 4 via a self-hosted endpoint (free, runs on a LAN/Tailscale host) ─
# OpenAI-compatible endpoint. Tested against Ollama; any OpenAI-compatible server works.
# Example (Ollama):
#   GEMMA_API_BASE=http://<your-host>:11434/v1
#   GEMMA_MODEL=gemma3:4b
# Use a multimodal Gemma 3 tag (4b/12b/27b) — gemma3n:* is text-only and won't read receipts.
# Leave GEMMA_API_BASE empty to disable. The "Process with Gemma 4" button only appears when it is set.
GEMMA_API_BASE=
GEMMA_MODEL=gemma3:4b

# ── Source Folder (cleanup after processing) ────────────────
# If set, the app offers to delete the original file from this folder
# after a receipt is processed. Leave empty to disable.
OHANTERADE_FOLDER=
